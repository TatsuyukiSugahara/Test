      "duration": 2.0,
      "looping": false,
      "maxParticles": 64,
      "simulationSpace": "Local",
      "gravityModifier": { "mode": "Constant", "constant": -0.05 },
      "initial": {
        "lifetime": { "mode": "TwoConstants", "min": 1.2, "max": 2.0 },
        "speed":    { "mode": "TwoConstants", "min": 0.5, "max": 1.5 },
        "size":     { "mode": "TwoConstants", "min": 0.6, "max": 1.0 },
        "rotation": { "mode": "TwoConstants", "min": 0.0, "max": 360.0 },
        "color":    { "mode": "Constant", "color": [0.5, 0.5, 0.5, 1.0] }
      },
      "emission": {
        "enabled": true,
        "rateOverTime": { "mode": "Constant", "constant": 0.0 },
        "bursts": [
          { "time": 0.0, "count": { "mode": "Constant", "constant": 20.0 }, "cycles": 1, "interval": 0.01, "probability": 1.0 }
        ]
      },
      "shape": {
        "enabled": true,
        "type": "Cone",
        "angle": 18.0,
        "radius": 0.2,
        "radiusThickness": 1.0
      },
      "sizeOverLifetime": {
        "enabled": true,
        "size": {
          "mode": "Curve",
          "multiplier": 2.5,
          "curve": { "keys": [
            { "time": 0.0, "value": 0.4, "inTangent": 0.0, "outTangent": 1.0 },
            { "time": 1.0, "value": 1.0, "inTangent": 0.2, "outTangent": 0.0 }
          ] }
        }
      },
      "rotationOverLifetime": {
        "enabled": true,
        "angularVelocity": { "mode": "TwoConstants", "min": -30.0, "max": 30.0 }
      },
      "colorOverLifetime": {
        "enabled": true,
        "gradient": {
          "colorKeys": [
            { "time": 0.0, "color": [0.35, 0.35, 0.35] },
