# ============================================================
# ビルド出力 / Build Outputs
# ============================================================

# Visual Studio ビルド成果物
x64/
Debug/
Release/
*.obj
*.pdb
*.ilk
*.exe
*.dll

# Source folders that intentionally use "Debug" in their path
!DirectX/aqEngine/UI/Debug/
!DirectX/aqEngine/UI/Debug/**
!DirectX/aqEngine/Sound/Authoring/Debug/
!DirectX/aqEngine/Sound/Authoring/Debug/**

# ============================================================
# サードパーティ コンパイル済みライブラリ / ThirdParty Compiled Libs
# ============================================================

DirectX/ThirdParty/BulletPhysics/bin/
DirectX/ThirdParty/BulletPhysics/lib/
DirectX/ThirdParty/DirectXTex/x64/

# ============================================================
# 個人設定 / Personal / IDE Settings
# ============================================================

# Visual Studio ローカルキャッシュ・個人設定
.vs/
*.vcxproj.user

# VS Code ワークスペース設定
.vscode/

# Claude Code 設定(個人/マシン固有の設定は除外。ただし共有スキルは追跡)
# 親を .claude/* にしないと配下の再包含(!)が効かない
.claude/*
!.claude/skills/

# Vulkan validation log (runtime)
vk_debug.log
# stray imgui.ini when run from DirectX/ (proper one is Game/imgui.ini)
/DirectX/imgui.ini

# Vulkan SDK installer (~300MB, GitHub 100MB 上限超のため除外。bat が自動DL)
Tools/SetupVulkan/*.exe

# ============================================================
# UWP / Xbox(道A)ビルド生成物 / Build artifacts
# ============================================================

# appx / msix パッケージ出力(アプリ パッケージの作成)
DirectX/AppPackages/
*.appx
*.appxbundle
*.msix
*.msixbundle
*.appxsym
*.appxupload

# CppWinRT / MSBuild が生成する projection 等
Generated Files/

# NuGet 復元パッケージ(directxtex_uwp / CppWinRT など。復元で再取得される)
DirectX/packages/

# パッケージ署名用のテスト証明書(秘密鍵はコミットしない)
*.pfx
*.cer

# 市販 VFX パック由来のエクスポート産物(再配布回避のためコミットしない)
DirectX/Game/Assets/Particle/FX_Fireball.particle
DirectX/Game/Assets/Particle/FX_LightPillar.particle
DirectX/Game/Assets/Particle/Textures/
DirectX/Game/Assets/Particle/Meshes/
